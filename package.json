{
  "name": "madeonsol-x402",
  "version": "1.12.0",
  "description": "Official TypeScript SDK for the MadeOnSol Solana API — KOL wallet tracking, Pump.fun deployer intelligence, x402 micropayments, and the all-DEX trade firehose. Free tier at madeonsol.com/pricing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "preflight": "bash ../../scripts/preflight-publish.sh",
    "prepublishOnly": "npm run preflight && npm run build"
  },
  "keywords": [
    "solana",
    "x402",
    "kol",
    "kol-tracker",
    "trading",
    "api",
    "micropayments",
    "ai-agent",
    "memecoin",
    "memecoin-tracker",
    "alpha",
    "alpha-bot",
    "copy-trading",
    "copy-trade",
    "pumpfun",
    "pumpfun-sniper",
    "deployer-hunter",
    "smart-money",
    "trade-stream",
    "solana-trading-bot",
    "madeonsol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LamboPoewert/madeonsol-x402"
  },
  "peerDependencies": {
    "@x402/fetch": ">=0.0.1",
    "@x402/svm": ">=0.0.1",
    "@x402/core": ">=0.0.1",
    "@solana/kit": ">=2.0.0",
    "@scure/base": ">=1.0.0"
  }
}
